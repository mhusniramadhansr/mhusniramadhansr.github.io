---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/baseLayout.astro";
const logoTechStack = await getEntry("skill", "logo");
---

<BaseLayout title="home">
  <main class="mt-10 text-justify mb-20">
    <div class="flex justify-center mb-10">
      <div class="relative w-64 h-64">
        <!-- Background gradient circle -->
        <div class="absolute inset-0 bg-gradient-to-br from-purple-600 to-pink-500 rounded-full opacity-75 blur-2xl -z-10 animate-pulse"></div>
        
        <!-- Outer ring -->
        <div class="absolute inset-0 rounded-full p-1 bg-gradient-to-r from-purple-600 via-pink-500 to-red-500"></div>

        <!-- Rocket icon -->
        <div class="absolute top-4 right-4 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-white/95 text-2xl shadow-lg shadow-pink-500/30 animate-bounce-slow dark:bg-slate-900/90 dark:text-pink-400">
          🚀
        </div>
        <!-- "Go!" label near rocket -->
          <div class="absolute top-4 z-10 px-3 py-1 text-sm font-semibold bg-white/95 dark:bg-slate-900/90 text-pink-500 rounded-full shadow-sm transform rotate-6 animate-bounce-slow" style="right:-48px;">
          Go!
        </div>
        
        <!-- Image container -->
        <div class="absolute inset-1 bg-white dark:bg-gray-900 rounded-full overflow-hidden">
          <img
            src="/images/me.jpeg"
            alt="Photo"
            width={200}
            height={200}
            class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
          />
        </div>
        
        <!-- Shine effect -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-white/20 to-transparent pointer-events-none"></div>
      </div>
    </div>
    <div class="animate-fade-in-up-loop">
      <h1
        class="text-2xl md:text-3xl font-bold border-b-4 border-purple-600 inline-block pb-2 relative animate-glow-pulse"
      >
        About Me
        <div class="absolute bottom-0 left-0 h-1 bg-gradient-to-r from-purple-600 to-pink-500 rounded-full"></div>
      </h1>
    </div>
    
    <div class="space-y-5 mt-8">
      <div class="animate-slide-in-right" style="animation-delay: 0.2s">
        <p class="text-base md:text-lg text-gray-800 dark:text-gray-200 leading-relaxed">
          Hi! I'm <span class="font-bold bg-gradient-to-r from-purple-600 to-pink-500 bg-clip-text text-transparent inline-block">M. Husni Ramadhan, S.T</span>, a graduate of Universitas Putra Indonesia with a Bachelor’s degree in Informatics Engineering, graduating with Cumlaude honors. I possess strong communication and interpersonal skills, a passion for continuous learning, and the ability to work effectively both independently and within a team. I am highly adaptable, quick to learn, and able to thrive in fast-paced and dynamic environments.
        </p>
      </div>
      
      <div class="animate-slide-in-right" style="animation-delay: 0.4s">
        <p class="text-base md:text-lg text-gray-800 dark:text-gray-200 leading-relaxed">
          I'm a passionate and dedicated software developer specializing in frontend and backend development. With a keen interest in creating efficient and scalable solutions, I take pride in ensuring high-performance and reliable applications.
        </p>
      </div>

      <div class="animate-slide-in-right" style="animation-delay: 0.6s">
        <p class="text-base md:text-lg text-gray-800 dark:text-gray-200 leading-relaxed">
          I'm always eager to stay updated with the latest trends and technologies. I believe in continuous learning and improvement to deliver cutting-edge solutions. On good days, I love to explore about technology especially on programming.
        </p>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <div class="animate-fade-in-up-loop inline-flex items-center gap-2 px-4 py-2 rounded-full border border-purple-300 bg-gradient-to-r from-purple-100 via-purple-200 to-pink-100 text-purple-900 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-purple-700 dark:from-purple-900/40 dark:via-purple-800/40 dark:to-pink-900/30 dark:text-purple-200" style="animation-delay: 0.95s">
          <span class="text-2xl">💻</span>
          <span class="text-sm font-medium">Web Development</span>
        </div>
        <div class="animate-fade-in-up-loop inline-flex items-center gap-2 px-4 py-2 rounded-full border border-amber-300 bg-gradient-to-r from-amber-100 via-amber-200 to-orange-100 text-amber-900 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-amber-700 dark:from-amber-900/40 dark:via-amber-800/40 dark:to-orange-900/30 dark:text-amber-200" style="animation-delay: 0.9s">
          <span class="text-2xl">📄</span>
          <span class="text-sm font-medium">Microsoft Office</span>
        </div>
        <div class="animate-fade-in-up-loop inline-flex items-center gap-2 px-4 py-2 rounded-full border border-sky-300 bg-gradient-to-r from-sky-100 via-sky-200 to-cyan-100 text-sky-900 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-sky-700 dark:from-sky-900/40 dark:via-sky-800/40 dark:to-cyan-900/30 dark:text-sky-200" style="animation-delay: 1s">
          <span class="text-2xl">🛠️</span>
          <span class="text-sm font-medium">IT Support Specialist</span>
        </div>
        <div class="animate-fade-in-up-loop inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-300 bg-gradient-to-r from-emerald-100 via-emerald-200 to-emerald-100 text-emerald-900 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg dark:border-emerald-700 dark:from-emerald-900/40 dark:via-emerald-800/40 dark:to-emerald-900/30 dark:text-emerald-200" style="animation-delay: 1.1s">
          <span class="text-2xl">🌐</span>
          <span class="text-sm font-medium">Network Administration</span>
        </div>
      </div>
    </div>
    <h1
      class="text-2xl md:text-3xl font-bold border-b-4 border-purple-600 inline-block my-5 animate-fade-in-up-loop"
    >
      Skills
    </h1>
    <div class="flex flex-wrap gap-5 justify-center">
      {
        logoTechStack.data.map((v: { src?: string; alt?: string }, index: number) => (
          <img 
            width="46" 
            height="46" 
            src={v.src} 
            alt={v.alt}
            class="animate-fade-in-up-loop hover:scale-110 transition-transform duration-300"
            style={`animation-delay: ${index * 0.1}s`}
          />
        ))
      }
    </div>
  </main>
</BaseLayout>
